@startuml
!theme plain
skinparam defaultFontName Arial
skinparam defaultFontSize 13

title System Flowchart

start
:Power on Pi;
:Init GPIO, Camera, Model;

repeat
  :Measure distance;

  if (< 30 cm?) then (Yes)
    :Capture image;
    :Classify waste;

    if (Confidence > 65%?) then (Yes)
      if (Recyclable?) then (Yes)
        :Open recycle bin;
      else (No)
        :Open trash bin;
      endif
    else (No)
      :Open trash bin;
    endif

    :Wait 2 s;
    :Close servos;
    :Cooldown 2 s;
  else (No)
    :Sleep 0.2 s;
  endif

repeat while (Loop)

stop
@enduml
